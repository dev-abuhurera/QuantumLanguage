int n = 5;

int i = 1;
while i <= n:
    int space = 1;
    while space <= n - i:
        printf(" ");
        space++;

    int j = 1;
    while j <= (2 * i - 1):
        printf("*");
        j++;

    cout << endl;
    i++;

// Bottom half
i = n - 1;
while i >= 1:
    int space = 1;
    while space <= n - i:
        printf(" ");
        space++;

    int j = 1;
    while j <= (2 * i - 1):
        printf("*");
        j++;

    cout << endl;
    i--;