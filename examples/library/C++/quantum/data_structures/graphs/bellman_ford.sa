// Bellman-Ford Algorithm Implementation in C++
#include <iostream>
#include <vector>
#include <climits>
using namespace std;

struct Edge {
    int source;
    int destination;
    int weight;
    
    Edge(int src, int dest, int w) : source(src), destination(dest), weight(w) {}
};

class BellmanFordGraph {
private:
    vector<Edge> edges;
    int vertices;

public:
    BellmanFordGraph(int v) : vertices(v) {}

    void addEdge(int u, int v, int weight) {
        if (u >= 0 && u < vertices && v >= 0 && v < vertices) {
            edges.push_back(Edge(u, v, weight));
        }
    }

    vector<int> bellmanFord(int startVertex) {
        vector<int> distance(vertices, INT_MAX);
        vector<int> parent(vertices, -1);

        if (startVertex >= 0 && startVertex < vertices) {
            distance[startVertex] = 0;

            for (int i = 0; i < vertices - 1; i++) {
                for (const Edge& edge : edges) {
                    int u = edge.source;
                    int v = edge.destination;
                    int weight = edge.weight;

                    if (distance[u] != INT_MAX && distance[u] + weight < distance[v]) {
                        distance[v] = distance[u] + weight;
                        parent[v] = u;
                    }
                }
            }

            for (const Edge& edge : edges) {
                int u = edge.source;
                int v = edge.destination;
                int weight = edge.weight;

                if (distance[u] != INT_MAX && distance[u] + weight < distance[v]) {
                    cout << "Graph contains negative weight cycle!" << endl;
                    return {};
                }
            }
        }

        return distance;
    }

    vector<int> getShortestPath(int start, int end) {
        vector<int> distance(vertices, INT_MAX);
        vector<int> parent(vertices, -1);

        vector<int> path;

        if (start >= 0 && start < vertices && end >= 0 && end < vertices) {
            distance[start] = 0;

            for (int i = 0; i < vertices - 1; i++) {
                for (const Edge& edge : edges) {
                    int u = edge.source;
                    int v = edge.destination;
                    int weight = edge.weight;

                    if (distance[u] != INT_MAX && distance[u] + weight < distance[v]) {
                        distance[v] = distance[u] + weight;
                        parent[v] = u;
                    }
                }
            }

            if (distance[end] != INT_MAX) {
                for (int at = end; at != -1; at = parent[at]) {
                    path.push_back(at);
                }
                reverse(path.begin(), path.end());
            }
        }

        return path;
    }

    void displayDistances(const vector<int>& distances, int startVertex) {
        cout << "Shortest distances from vertex " << startVertex << ":" << endl;
        for (int i = 0; i < vertices; i++) {
            if (distances[i] == INT_MAX) {
                cout << i << ": Unreachable" << endl;
            } else {
                cout << i << ": " << distances[i] << endl;
            }
        }
    }

    void displayPath(const vector<int>& path, int start, int end) {
        cout << "Shortest path from " << start << " to " << end << ": ";
        if (path.empty()) {
            cout << "No path exists" << endl;
        } else {
            for (int i = 0; i < path.size(); i++) {
                cout << path[i];
                if (i < path.size() - 1) {
                    cout << " -> ";
                }
            }
            cout << endl;
        }
    }

    void display() {
        cout << "Graph edges:" << endl;
        for (const Edge& edge : edges) {
            cout << edge.source << " -> " << edge.destination << " (weight: " << edge.weight << ")" << endl;
        }
    }
};

int main() {
    BellmanFordGraph g(5);
    
    g.addEdge(0, 1, 6);
    g.addEdge(0, 2, 7);
    g.addEdge(1, 2, 8);
    g.addEdge(1, 3, 5);
    g.addEdge(1, 4, -4);
    g.addEdge(2, 3, -3);
    g.addEdge(2, 4, 9);
    g.addEdge(3, 1, -2);
    g.addEdge(4, 0, 2);
    g.addEdge(4, 3, 7);
    
    g.display();
    cout << endl;
    
    int startVertex = 0;
    vector<int> distances = g.bellmanFord(startVertex);
    if (!distances.empty()) {
        g.displayDistances(distances, startVertex);
    }
    
    cout << "\nShortest paths:" << endl;
    vector<int> path1 = g.getShortestPath(0, 3);
    g.displayPath(path1, 0, 3);
    
    vector<int> path2 = g.getShortestPath(4, 2);
    g.displayPath(path2, 4, 2);
    
    return 0;
}
