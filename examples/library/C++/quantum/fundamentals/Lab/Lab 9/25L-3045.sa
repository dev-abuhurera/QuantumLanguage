	int ques;
	cout << "Which Question do you want to check Enter 1,2,3,4,5,6,7,8 for Q1,Q2,Q3,Q4,Q5,Q6,Q7,Q8 respectively: ";
	cin >> ques;
	if (ques == 1)
	{
		Q1();
	}
	else if (ques == 2) {
		Q2();
	}
	else if (ques == 3) {
		Q3();
	}
	else if (ques == 4) {
		Q4();
	}
	else if (ques == 5) {
		Q5();
	}
	else if (ques == 6) {
		Q6();
	}
	else if (ques == 7) {
		Q7();
	}
	else {
		Q8();
	}
}