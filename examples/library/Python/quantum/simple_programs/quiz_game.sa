# Quiz Game
# Interactive quiz with multiple choice questions

class Question:
    def __init__(self, question_text, options, correct_answer, explanation=""):
        self.question_text = question_text
        self.options = options
        self.correct_answer = correct_answer
        self.explanation = explanation
    
    def check_answer(self, user_answer):
        return user_answer.lower() == self.correct_answer.lower()
    
    def display(self):
        print(f"\n{self.question_text}")
        for i, option in enumerate(self.options, 1):
            print(f"{i}. {option}")

class Quiz:
    def __init__(self, title):
        self.title = title
        self.questions = []
        self.score = 0
        self.total_questions = 0
        self.answers = []
    
    def add_question(self, question):
        self.questions.append(question)
    
    def run_quiz(self):
        print(f"\n{self.title}")
        print("=" * len(self.title))
        
        self.score = 0
        self.total_questions = len(self.questions)
        self.answers = []
        
        for i, question in enumerate(self.questions, 1):
            question.display()
            
            while True:
                try:
                    answer = input(f"\nYour answer (1-{len(question.options)}): ")
                    answer_num = int(answer)
                    
                    if 1 <= answer_num <= len(question.options):
                        user_answer = question.options[answer_num - 1]
                        is_correct = question.check_answer(user_answer)
                        
                        self.answers.append({
                            'question': question.question_text,
                            'user_answer': user_answer,
                            'correct_answer': question.correct_answer,
                            'is_correct': is_correct
                        })
                        
                        if is_correct:
                            print("✓ Correct!")
                            self.score += 1
                        else:
                            print("✗ Incorrect!")
                            print(f"The correct answer is: {question.correct_answer}")
                        
                        if question.explanation:
                            print(f"Explanation: {question.explanation}")
                        
                        break
                    else:
                        print(f"Please enter a number between 1 and {len(question.options)}")
                
                except ValueError:
                    print("Please enter a valid number")
            
            print(f"\nScore: {self.score}/{i}")
            if i < len(self.questions):
                input("Press Enter to continue...")
        
        self.show_results()
    
    def show_results(self):
        percentage = (self.score / self.total_questions) * 100
        
        print(f"\n{'='*40}")
        print(f"QUIZ RESULTS")
        print(f"{'='*40}")
        print(f"Final Score: {self.score}/{self.total_questions}")
        print(f"Percentage: {percentage:.1f}%")
        
        if percentage >= 90:
            grade = "Excellent! 🌟"
        elif percentage >= 80:
            grade = "Great job! 👍"
        elif percentage >= 70:
            grade = "Good effort! 👌"
        elif percentage >= 60:
            grade = "Keep practicing! 📚"
        else:
            grade = "Study more! 💪"
        
        print(f"Grade: {grade}")
        
        # Show detailed results
        print(f"\n{'='*40}")
        print("DETAILED RESULTS")
        print(f"{'='*40}")
        
        for i, answer in enumerate(self.answers, 1):
            status = "✓" if answer['is_correct'] else "✗"
            print(f"\nQuestion {i}: {status}")
            print(f"Your answer: {answer['user_answer']}")
            print(f"Correct answer: {answer['correct_answer']}")

def create_math_quiz():
    """Create a math quiz"""
    quiz = Quiz("Mathematics Quiz")
    
    questions = [
        Question(
            "What is 15 + 27?",
            ["40", "42", "44", "46"],
            "42",
            "15 + 27 = 42"
        ),
        Question(
            "What is 8 × 7?",
            ["54", "56", "58", "60"],
            "56",
            "8 × 7 = 56"
        ),
        Question(
            "What is 144 ÷ 12?",
            ["10", "11", "12", "13"],
            "12",
            "144 ÷ 12 = 12"
        ),
        Question(
            "What is 15²?",
            ["225", "215", "205", "195"],
            "225",
            "15² = 15 × 15 = 225"
        ),
        Question(
            "What is the square root of 64?",
            ["6", "7", "8", "9"],
            "8",
            "√64 = 8 because 8 × 8 = 64"
        )
    ]
    
    for question in questions:
        quiz.add_question(question)
    
    return quiz

def create_science_quiz():
    """Create a science quiz"""
    quiz = Quiz("Science Quiz")
    
    questions = [
        Question(
            "What is the chemical symbol for gold?",
            ["Go", "Gd", "Au", "Ag"],
            "Au",
            "Au comes from the Latin word 'aurum' meaning gold"
        ),
        Question(
            "What planet is known as the Red Planet?",
            ["Venus", "Mars", "Jupiter", "Saturn"],
            "Mars",
            "Mars appears red due to iron oxide on its surface"
        ),
        Question(
            "What is the speed of light?",
            ["299,792 km/s", "199,792 km/s", "399,792 km/s", "499,792 km/s"],
            "299,792 km/s",
            "The speed of light in vacuum is approximately 299,792 kilometers per second"
        ),
        Question(
            "What is the largest organ in the human body?",
            ["Heart", "Liver", "Brain", "Skin"],
            "Skin",
            "The skin is the body's largest organ, covering about 20 square feet"
        ),
        Question(
            "What gas do plants absorb from the atmosphere?",
            ["Oxygen", "Nitrogen", "Carbon Dioxide", "Hydrogen"],
            "Carbon Dioxide",
            "Plants use carbon dioxide for photosynthesis and release oxygen"
        )
    ]
    
    for question in questions:
        quiz.add_question(question)
    
    return quiz

