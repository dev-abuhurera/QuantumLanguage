            ["London", "Berlin", "Paris", "Madrid"],
            "Paris",
            "Paris has been the capital of France since 987 AD"
        ),
        Question(
            "Which is the largest ocean?",
            ["Atlantic", "Indian", "Arctic", "Pacific"],
            "Pacific",
            "The Pacific Ocean covers about 63 million square miles"
        ),
        Question(
            "What is the longest river in the world?",
            ["Amazon", "Nile", "Mississippi", "Yangtze"],
            "Nile",
            "The Nile River is about 4,132 miles long"
        ),
        Question(
            "Which country has the largest population?",
            ["India", "China", "USA", "Indonesia"],
            "China",
            "China has over 1.4 billion people"
        ),
        Question(
            "What is the smallest continent?",
            ["Australia", "Europe", "Antarctica", "South America"],
            "Australia",
            "Australia is the smallest continent at about 3 million square miles"
        )
    ]
    
    for question in questions:
        quiz.add_question(question)
    
    return quiz

def create_programming_quiz():
    """Create a programming quiz"""
    quiz = Quiz("Programming Quiz")
    
    questions = [
        Question(
            "What does 'HTML' stand for?",
            ["Hyper Text Markup Language", "High Tech Modern Language", "Home Tool Markup Language", "Hyperlinks and Text Markup Language"],
            "Hyper Text Markup Language",
            "HTML is the standard markup language for creating web pages"
        ),
        Question(
            "Which of these is not a programming language?",
            ["Python", "Java", "HTML", "C++"],
            "HTML",
            "HTML is a markup language, not a programming language"
        ),
        Question(
            "What does 'CSS' stand for?",
            ["Computer Style Sheets", "Creative Style Sheets", "Cascading Style Sheets", "Colorful Style Sheets"],
            "Cascading Style Sheets",
            "CSS is used to style and layout web pages"
        ),
        Question(
            "Which symbol is used for comments in Python?",
            ["//", "#", "/* */", "--"],
            "#",
            "In Python, # is used to create single-line comments"
        ),
        Question(
            "What is a 'variable'?",
            ["A container for storing data", "A type of loop", "A mathematical operation", "A programming language"],
            "A container for storing data",
            "Variables are used to store information that can be referenced and manipulated"
        )
    ]
    
    for question in questions:
        quiz.add_question(question)
    
    return quiz

def custom_quiz():
    """Create a custom quiz with user input"""
    print("Create Your Own Quiz")
    print("=" * 25)
    
    quiz_title = input("Enter quiz title: ")
    quiz = Quiz(quiz_title)
    
    while True:
        print(f"\nQuestion {len(quiz.questions) + 1}")
        question_text = input("Enter question: ")
        
        print("Enter 4 answer options:")
        options = []
        for i in range(4):
            option = input(f"Option {i+1}: ")
            options.append(option)
        
        while True:
            try:
                correct_num = int(input("Enter number of correct answer (1-4): "))
                if 1 <= correct_num <= 4:
                    correct_answer = options[correct_num - 1]
                    break
                else:
                    print("Please enter a number between 1 and 4")
            except ValueError:
                print("Please enter a valid number")
        
        explanation = input("Enter explanation (optional): ")
        
        question = Question(question_text, options, correct_answer, explanation)
        quiz.add_question(question)
        
        another = input("Add another question? (y/n): ").lower()
        if another != 'y':
            break
    
    return quiz

def quiz_game():
    """Main quiz game menu"""
    print("Welcome to Quiz Game!")
    print("=" * 25)
    
    while True:
        print("\nSelect a Quiz Category:")
        print("1. Mathematics")
        print("2. Science")
        print("3. Geography")
        print("4. Programming")
        print("5. Create Custom Quiz")
        print("6. Exit")
        
        choice = input("Enter your choice (1-6): ")
        
        if choice == '1':
            quiz = create_math_quiz()
            quiz.run_quiz()
        
        elif choice == '2':
            quiz = create_science_quiz()
            quiz.run_quiz()
        
        elif choice == '3':
            quiz = create_geography_quiz()
            quiz.run_quiz()
        
        elif choice == '4':
            quiz = create_programming_quiz()
            quiz.run_quiz()
        
        elif choice == '5':
            quiz = custom_quiz()
            if quiz.questions:
                quiz.run_quiz()
        
        elif choice == '6':
            print("Thanks for playing!")
            break
        
        else:
            print("Invalid choice. Please try again.")
        
        if choice != '6':
            play_again = input("\nPlay another quiz? (y/n): ").lower()
            if play_again != 'y':
                print("Thanks for playing!")
                break

# Run the quiz game
quiz_game()
